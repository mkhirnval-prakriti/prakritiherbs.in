# ============================================================
# KamaSutra Gold+ by Prakriti Herbs — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# --- Database ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Admin Panel ---
ADMIN_USERNAME=prakriti_admin
ADMIN_PASSWORD=YourSecurePasswordHere
JWT_SECRET=your_jwt_secret_here_min_32_chars

# --- Facebook Meta CAPI ---
META_ACCESS_TOKEN=your_meta_capi_access_token

# --- SMTP Email (Hostinger or other) ---
SMTP_HOST=smtp.hostinger.com
SMTP_USER=contact@prakritiherbs.in
SMTP_PASS=your_smtp_password
SMTP_PORT=465

# --- Payment Gateways ---
# Cashfree
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_ENV=PROD

# Razorpay (if used)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# --- WhatsApp Business API (if used) ---
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
